{
  "layer": "top", // Waybar at top layer
  "position": "top", // Waybar position (top|bottom|left|right)
  "height": -2,
  "margin": "0 0 0 0",
  //"width": 1350, // Waybar width
  // Choose the order of the modules idle_inhibitor
  "modules-left": [
    "custom/launcher",
    "river/tags",
    //"custom/swap",
    "mpd#2",
    "mpd#3",
    "mpd#4",
    "mpd"
  ],
  "modules-center": ["clock"],
  "modules-right": [
    //"backlight",
    "tray",
    "network",
    "pulseaudio",
    "temperature",
    //"custom/clipboard",
    "cpu",
    "memory",
    "battery",
    "custom/power"
  ],

  // Modules configuration

   "river/tags": {
		"num-tags": 9,
      "tag-labels": ["1", "2", "3", "4", "5", "6","7","8","9"]
    },

  "mpd": {
    "tooltip": true,
    "tooltip-format": "{artist} - {album} - {title} - Total Time : {totalTime:%M:%S}",
    "format": "’ŗ▓ {elapsedTime:%M:%S}",
    "format-disconnected": "ŌÜĀ  Disconnected",
    "format-stopped": "’ŗ▓ Not Playing",
    "on-click": "mpc toggle",
    "state-icons": {
      "playing": "’üŗ",
      "paused": "’üī"
    }
  },
  "mpd#2": {
    "format": "’üł",
    "format-disconnected": "’üł",
    "format-paused": "’üł",
    "format-stopped": "’üł",
    // Commands to execute on events
    "on-click": "mpc -q pause && mpc -q prev && mpc -q start"
  },
  "mpd#3": {
    "interval": 1,
    "format": "{stateIcon}",
    "format-disconnected": "’üŗ",
    "format-paused": "{stateIcon}",
    "format-stopped": "’üŗ",
    "state-icons": {
      "paused": "’üŗ",
      "playing": "’üī"
    },
    // Commands to execute on events
    "on-click": "mpc toggle"
  },
  "mpd#4": {
    "format": "’üæ",
    "format-disconnected": "’üæ",
    "format-paused": "’üæ",
    "format-stopped": "’üæ",
    // Commands to execute on events
    "on-click": "mpc -q pause && mpc -q next && mpc -q start"
  },
  "custom/swap": {
    "on-click": "~/.config/waybar/river/scripts/swap.sh",
    "tooltip": "Swap between waybar configs",
    "format": "Bg ’łä "
  },
  "custom/mpd": {
    "format": "’Ćü {title} - {artist}",
    "interval": 5,
    "exec": "mpc current --format='\"title\":\"%title%\",\"artist\":\"%artist%\"'"
  }, 
  
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "’ü«",
      "deactivated": "’ü░"
    }
  },
  "tray": {
    "icon-size": 14,
    "spacing": 15
  },
  "clock": {
    "format": "{:%a %d %b %Y | %H:%M:%S}", //12 hour format ’ä│  ’ĆŚ 
    "interval": 1,
    "tooltip-format": "<tt> {calendar} </tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    },
  },
  "cpu": {
    "format": "’Æ╝ {usage: 1}%",
    "on-click": "foot -e btop"
  },
  "memory": {
    "format": "’ŗø {: >1}%",
    "on-click": "foot -e btop"
  },
 "temperature": {
        //"tooltip":false,
        //"thermal-zone": 2,
        //"hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
        "critical-threshold": 80,
        "format-critical": "’ŗē {temperatureC}┬░C",
        "format": "’ŗē {temperatureC}┬░C",
        //"on-click": "foot -e sensors"
    },
  "backlight": {
    // "device": "acpi_video1",
    "format": "{icon} {percent: >3}%",
    "format-icons": ["’åģ", "’éŻ"],
    "on-scroll-down": "brightnessctl -c backlight set 5%-",
    //"on-scroll-down": "light -A 5",
    "on-scroll-up": "brightnessctl -c backlight set +5%"
    //"on-scroll-up": "light -U 5"
  },
  "battery": {
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity: >3}%",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"]
  },
  "network": {
    // "interface": "wlp2s0", // (Optional) To force the use of this interface
    "format": "ŌÜĀ  Disabled",
    "format-wifi": "’ć½  {essid}",
    // "format-ethernet": "’āü {ifname}: {ipaddr}/{cidr}",
    "format-ethernet": "’āü  Wired",
    "format-disconnected": "ŌÜĀ Disconnected",
    // "on-click": "foot -e nmtui"
    "on-click": "nm-connection-editor"
  },
  "pulseaudio": {
    "scroll-step": 1,
    "format": "{icon} {volume: >3}%",
    "format-bluetooth": "{icon} {volume: >3}%",
    "format-muted": "’Ć” muted",
    "format-icons": {
      "headphones": "’Ćź",
      "handsfree": "’Ćź",
      "headset": "’Ćź",
      "phone": "’éĢ",
      "portable": "’éĢ",
      "car": "’å╣",
      "default": ["’Ć¦", "’Ć©"]
    },
    "on-click": "pavucontrol",
    "on-scroll-up": "pamixer -ui 2",
    "on-scroll-down": "pamixer -ud 2"
  }, 
 "custom/power": {
    "format": "ŌÅ╗  ",
    "on-click": "menusys",
    "tooltip": false
  }, 
  "custom/launcher": {
    "format": "||",
    "on-click": "fuzzel",
    "tooltip": false
  },
  "custom/clipboard":{
        "format":"¾░ģŹ Clip",
        "tooltip":false,
        "on-click": "~/.config/river/scripts/clip"
    },
}
